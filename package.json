{
  "name": "shortflow-studio",
  "version": "1.0.0",
  "private": true,
  "description": "Production-oriented short-form workflow panel for Adobe Premiere Pro.",
  "license": "UNLICENSED",
  "type": "commonjs",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "clean": "rimraf dist .test-build .ai-test-build .thumbnail-test-build .job-test-build .recovery-test-build .final-qc-test-build release",
    "build": "vite build && npm run verify:dist",
    "beta:evidence": "node scripts/collect-beta-evidence.mjs",
    "beta:evidence:verified": "npm run check && npm run package:ccx:force && node scripts/collect-beta-evidence.mjs --verified",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test:compile": "rimraf .test-build && tsc -p tsconfig.test.json",
    "test": "npm run test:compile && node scripts/run-tests.mjs",
    "check": "npm run typecheck && npm run lint && npm run build && npm test",
    "verify:dist": "node scripts/verify-dist.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "verify:speech": "node scripts/verify-speech-live.mjs",
    "verify:speech:live": "node scripts/verify-speech-live.mjs --live",
    "verify:speech:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-local-whisper.ps1",
    "package:ccx": "npm run build && node scripts/package-ccx.mjs && npm run verify:release",
    "package:ccx:force": "npm run build && node scripts/package-ccx.mjs --force && npm run verify:release"
  },
  "devDependencies": {
    "@adobe/cc-ext-uxp-types": "^7.3.1",
    "@adobe/eslint-plugin-premierepro": "^26.3.0",
    "@adobe/premierepro": "^26.3.0",
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.10.2",
    "archiver": "^7.0.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0",
    "vite": "^7.3.0"
  }
}
